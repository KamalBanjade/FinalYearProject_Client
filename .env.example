# API Configuration
# Set to your PC's local IP address. Change this when your WiFi network changes.
NEXT_PUBLIC_API_URL=http://192.168.1.8:5004/api
NEXT_PUBLIC_APP_URL=http://192.168.1.8:3000

# Environment
NEXT_PUBLIC_ENV=development

# Feature Flags
NEXT_PUBLIC_ENABLE_2FA=true
NEXT_PUBLIC_ENABLE_EMAIL_VERIFICATION=false

# Session Configuration
NEXT_PUBLIC_SESSION_TIMEOUT_MINUTES=30

# Application Info
NEXT_PUBLIC_APP_NAME=Sajilo Swasthya
NEXT_PUBLIC_APP_VERSION=1.0.0
